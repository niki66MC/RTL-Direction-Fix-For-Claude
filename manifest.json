{
  "manifest_version": 2,
  "name": "Claude Hebrew RTL Fix",
  "version": "1.0",
  "description": "Fixes text direction for Hebrew responses on Claude.ai",
  "icons": {
    "48": "icon-48.svg"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon-48.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ]
}